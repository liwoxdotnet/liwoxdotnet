---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
import siteConfig from '@/config/site.config';

const location = siteConfig.address?.city
  ? `${siteConfig.address.city}${siteConfig.address.country ? `, ${siteConfig.address.country}` : ''}`
  : 'the UK';
---
<PageLayout
  title={`About — ${siteConfig.name}`}
  description="LiwoxDotNet is a UK-based digital engineering practice. We help businesses design, build, and scale modern digital systems using DevOps, cloud infrastructure, and clean engineering practices."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user" size="sm" />
      About LiwoxDotNet
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">We build</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={["digital systems", "cloud platforms", "DevOps pipelines", "web applications", "scalable infrastructure", "things that work"]} />
      </span>
    </h1>

    <p slot="description">
      LiwoxDotNet is a UK-based digital engineering practice. We help businesses move from concept to production without the usual complexity. Meet the authors. 
    </p>

  <!-- How We Work -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Our Approach</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            How We Work
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Every project at LiwoxDotNet is held to the same standard — from the first conversation to the final deployment.
        </p>
      </div>
      <div class="grid gap-8 md:grid-cols-3" data-reveal data-reveal-delay="1">
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layers" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Build with Structure</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Too many projects fail because they're built without a plan. We start every engagement by understanding the full picture — then build something that can actually grow.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Ship to Production</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                We don't just hand over code. We deploy it, monitor it, and make sure it works in the real world — not just in a local environment.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="trending-up" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Build to Scale</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Every system is designed with growth in mind. When your business scales, your infrastructure scales with it — without a costly rebuild.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <TechStack
    badge="Tools & Tech"
    title="Our Stack"
    description="The tools we rely on to build fast, reliable, production-ready systems — chosen for performance, maintainability, and proven results."
  />

  <!-- CTA -->
  <section class="py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-2xl px-6 text-center" data-reveal>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Ready to build something that lasts?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        If you need something built : from idea to production : LiwoxDotNet is where it happens. Let's have a conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact">
          Start a Project
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/blog">
          Read the Blog
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
