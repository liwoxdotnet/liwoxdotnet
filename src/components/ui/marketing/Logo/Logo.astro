---
/**
 * LiwoxDotNet Logo Component (Final)
 * Uses real brand assets instead of placeholder letter
 */

import { cn } from '@/lib/cn';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  class?: string;
}

const { size = 'md', class: className } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'h-5',
  md: 'h-6',
  lg: 'h-8',
  xl: 'h-12',
  '2xl': 'h-20',
};

const sizeClass = sizeClasses[size] ?? sizeClasses.md;

/**
 * Use icon for small sizes, seal for larger sizes
 */
const isSmall = size === 'sm' || size === 'md';
const logoSrc = isSmall
  ? '/brand/liwox-icon.png'
  : '/brand/liwox-seal.svg';
---

<img
  src={logoSrc}
  alt="LiwoxDotNet"
  class={cn('inline-block object-contain', sizeClass, className)}
  loading="eager"
/>
